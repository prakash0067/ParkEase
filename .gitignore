# 1. Node Dependencies (Huge files, let users install their own)
node_modules/

# 2. Environment Variables (CRITICAL SECURITY RISK)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 3. Production Builds (Generated code)
build/
dist/

# 4. Smart Contract Artifacts (Optional, but usually ignored)
# Note: If your React app reads directly from a build/contracts folder, 
# you might need to keep the specific ABI JSON file, but ignore the rest.
artifacts/
cache/
typechain-types/

# 5. OS Generated Files
.DS_Store
Thumbs.db

# 6. Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*